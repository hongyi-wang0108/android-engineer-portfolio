---
type Props = {
  title: string;
  skills: string[];
};

const { title, skills } = Astro.props;
---

<div class="soft-card rounded-2xl p-6">
  <h3 class="text-xl font-black">{title}</h3>
  <div class="mt-4 flex flex-wrap gap-2">
    {skills.map((skill) => (
      <span class="rounded-full bg-white/80 px-3 py-2 text-sm font-semibold text-muted">{skill}</span>
    ))}
  </div>
</div>
