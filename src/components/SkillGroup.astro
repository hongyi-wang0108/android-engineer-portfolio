---
type Props = {
  title: string;
  skills: string[];
};

const { title, skills } = Astro.props;

const chipColors = ["bg-mint", "bg-sky", "bg-rose", "bg-lemon", "bg-peach", "bg-cream"];
---

<div class="soft-card rounded-2xl p-6">
  <h3 class="text-xl font-black">{title}</h3>
  <div class="mt-4 flex flex-wrap gap-2">
    {skills.map((skill, index) => (
      <span class:list={["rounded-full px-3 py-2 text-sm font-semibold text-ink", chipColors[index % chipColors.length]]}>{skill}</span>
    ))}
  </div>
</div>
