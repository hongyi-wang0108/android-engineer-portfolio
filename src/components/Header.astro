---
const navItems = [
  { label: "About", href: "/#about" },
  { label: "Projects", href: "/#projects" },
  { label: "Personal", href: "/#personal-projects" },
  { label: "Skills", href: "/#skills" },
  { label: "Contact", href: "/#contact" }
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-ink/10 bg-cream/82 backdrop-blur-xl">
  <div class="section-shell flex h-20 items-center justify-between">
    <a class="focus-ring flex items-center gap-3 rounded-full" href="/">
      <span class="grid h-11 w-11 place-items-center rounded-full bg-ink text-sm font-black text-cream">HW</span>
      <span>
        <span class="block text-sm font-black">王泓懿</span>
        <span class="block text-xs font-semibold text-muted">Android Client Engineer</span>
      </span>
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {navItems.map((item) => (
        <a class="focus-ring rounded-full px-4 py-2 text-sm font-bold text-muted transition hover:bg-white/75 hover:text-ink" href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <details class="relative md:hidden">
      <summary class="focus-ring list-none rounded-full border border-ink/10 bg-white/75 px-4 py-2 text-sm font-bold text-ink">
        Menu
      </summary>
      <nav class="absolute right-0 mt-3 grid min-w-44 gap-1 rounded-2xl border border-ink/10 bg-white p-2 shadow-soft">
        {navItems.map((item) => (
          <a class="rounded-xl px-4 py-3 text-sm font-bold text-muted hover:bg-cream hover:text-ink" href={item.href}>
            {item.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>
