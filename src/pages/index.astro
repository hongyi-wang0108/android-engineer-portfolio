---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import SkillGroup from "../components/SkillGroup.astro";
import TagList from "../components/TagList.astro";
import { coreProjects, personalProjects } from "../data/projects";
import { currentStack, skillGroups } from "../data/skills";

const chipColors = ["bg-mint", "bg-sky", "bg-rose", "bg-lemon", "bg-peach", "bg-cream"];
const getYoutubeEmbedUrl = (youtubeId?: string) =>
  youtubeId
    ? `https://www.youtube.com/embed/${youtubeId}?autoplay=1&mute=1&loop=1&playlist=${youtubeId}&playsinline=1&rel=0`
    : undefined;
---

<BaseLayout
  title="王泓懿 | Android Client Engineer"
  description="Androidエンジニアとして、大規模アプリ開発、SDK安定性改善、ログイン基盤刷新、通信コスト最適化に取り組んできました。"
>
  <Header />
  <main>
    <section class="section-shell grid min-h-[calc(100vh-40px)] gap-10 pb-16 pt-32 lg:grid-cols-[1fr_410px] lg:items-center">
      <div>
        <p class="mb-4 text-sm font-black uppercase tracking-[0.2em] text-cocoa">Android Engineer Portfolio</p>
        <h1 class="max-w-4xl text-5xl font-black leading-[1.05] md:text-7xl">
          王泓懿
          <span class="mt-3 block text-3xl text-muted md:text-5xl">Android Client Engineer</span>
        </h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-muted md:text-xl md:leading-9">
          大規模Androidアプリ開発、SDK安定性改善、ログイン基盤刷新、通信コスト最適化に取り組んできました。
        </p>
        <div class="mt-7 flex flex-wrap gap-2">
          {["Android", "Kotlin", "Java", "SDK", "Stability", "Performance", "Cross-team Collaboration"].map((tag) => (
            <span class="rounded-full bg-white/75 px-4 py-2 text-sm font-bold text-muted shadow-sm">{tag}</span>
          ))}
        </div>
        <div class="mt-9 flex flex-wrap gap-3">
          <a class="focus-ring rounded-full bg-ink px-6 py-3 text-sm font-black text-cream transition hover:bg-cocoa" href="#projects">
            View Projects
          </a>
          <a class="focus-ring rounded-full border border-ink/15 bg-white/75 px-6 py-3 text-sm font-black text-ink transition hover:border-ink/30" href="#contact">
            Contact
          </a>
        </div>
      </div>

      <div class="soft-card relative overflow-hidden rounded-3xl p-6">
        <div class="absolute right-5 top-5 h-16 w-16 rounded-full bg-lemon/80"></div>
        <div class="absolute bottom-8 left-8 h-20 w-20 rounded-full bg-sky/80"></div>
        <div class="relative rounded-3xl bg-white/80 p-6">
          <div class="mx-auto grid h-44 w-44 place-items-center rounded-full bg-mint">
            <div class="relative h-28 w-32 rounded-[2rem] bg-white shadow-soft">
              <div class="absolute -left-3 top-3 h-11 w-9 -rotate-12 rounded-full bg-peach"></div>
              <div class="absolute -right-3 top-3 h-11 w-9 rotate-12 rounded-full bg-peach"></div>
              <div class="absolute left-9 top-11 h-3 w-3 rounded-full bg-ink"></div>
              <div class="absolute right-9 top-11 h-3 w-3 rounded-full bg-ink"></div>
              <div class="absolute left-1/2 top-16 h-4 w-5 -translate-x-1/2 rounded-full bg-cocoa"></div>
              <div class="absolute bottom-7 left-1/2 h-5 w-14 -translate-x-1/2 rounded-b-full border-b-4 border-cocoa"></div>
            </div>
          </div>
          <div class="mt-6 grid gap-3">
            <div class="rounded-2xl bg-cream p-4">
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-muted">Core Strength</p>
              <p class="mt-2 text-xl font-black">Stability, Architecture, Multi-device Android</p>
            </div>
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="flex min-h-[94px] flex-col items-center rounded-2xl bg-sky p-4">
                <p class="text-2xl font-black leading-none">4</p>
                <p class="mt-2 text-xs font-bold leading-4 text-muted">Core Projects</p>
              </div>
              <div class="flex min-h-[94px] flex-col items-center rounded-2xl bg-rose p-4">
                <p class="text-2xl font-black leading-none">3.5Y</p>
                <p class="mt-2 text-xs font-bold leading-4 text-muted">Experience</p>
              </div>
              <div class="flex min-h-[94px] flex-col items-center rounded-2xl bg-lemon p-4">
                <p class="text-xl font-black leading-none">JLPT N2</p>
                <p class="mt-2 text-xs font-bold leading-4 text-muted">合格</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section-shell py-16">
      <SectionTitle eyebrow="About" title="About" />
      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_380px]">
        <div class="soft-card rounded-2xl p-6 md:p-8">
          <p class="text-lg leading-9 text-muted">
            北京達佳互聯信息技術有限公司にて、約3.5年間Androidクライアントエンジニアとして従事しました。Kotlin / Java を用いた大規模インターネットサービスのAndroidアプリ開発を担当し、TV・Pad・スマートデバイス向けの機能開発、ログイン基盤の刷新、IMSDKの障害分析基盤構築、ネットワーク通信コスト最適化などのプロジェクトに携わりました。機能開発だけでなく、安定性、保守性、マルチデバイス対応、チーム間連携を意識した開発を強みとしています。
          </p>
        </div>
        <div class="grid gap-4">
          {[
            ["Stability Improvement", "障害分析、ログ設計、SOP整備を通じて、問題解決の再現性を高めました。"],
            ["Architecture / Maintainability", "ログイン基盤刷新などを通じて、拡張性と保守性を意識した設計改善に取り組みました。"],
            ["Performance / Cost Optimization", "通信量削減や圧縮対応により、サービス運用コストの最適化に貢献しました。"]
          ].map(([title, text]) => (
            <div class="soft-card rounded-2xl p-5">
              <h3 class="font-black">{title}</h3>
              <p class="mt-2 leading-7 text-muted">{text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="section-shell py-16">
      <SectionTitle
        eyebrow="Core Projects"
        title="Core Projects"
        subtitle="職務経歴書だけでは伝わりにくい、担当範囲・技術的な工夫・成果を整理しています。"
      />
      <div class="mt-9 grid gap-6 md:grid-cols-2">
        {coreProjects.map((project) => <ProjectCard project={project} href={`/projects/${project.slug}`} />)}
      </div>
    </section>

    <section id="personal-projects" class="section-shell py-16">
      <SectionTitle
        eyebrow="Personal Projects"
        title="Personal Projects"
        subtitle="Modern Android技術スタックを用いた個人開発デモです。GitHub ReleaseでAPKを公開し、Google Play公開に向けて準備中です。"
      />
      <div class="mt-9 grid gap-6">
        {personalProjects.map((project) => {
          const youtubeEmbedUrl = getYoutubeEmbedUrl(project.demoVideo?.youtubeId);

          return (
            <article class="project-card overflow-hidden rounded-3xl p-6 md:p-8">
              <div class="grid gap-8 lg:grid-cols-[1fr_460px]">
                <div>
                  <TagList tags={project.tags.slice(0, 7)} />
                  <h3 class="mt-5 text-3xl font-black leading-tight md:text-4xl">{project.title}</h3>
                  <p class="mt-4 text-lg font-bold text-cocoa">{project.subtitle}</p>
                  <p class="mt-5 leading-8 text-muted">{project.overview}</p>

                  {project.appLinks && (
                    <div class="mt-6 grid gap-3 sm:grid-cols-2">
                      {project.appLinks.map((link, index) => (
                        link.href ? (
                          <a class:list={["focus-ring group flex min-w-0 items-center justify-between gap-2 rounded-2xl border border-ink/10 px-4 py-3 text-sm font-black text-ink shadow-sm transition hover:-translate-y-0.5 hover:border-cocoa/30 hover:shadow-soft", index === 0 ? "bg-rose hover:bg-peach" : "bg-sky hover:bg-mint"]} href={link.href} target="_blank" rel="noreferrer">
                            <span class="min-w-0 truncate">{link.label}</span>
                            <span class="shrink-0 rounded-full bg-white/75 px-2.5 py-1 text-[11px] text-ink transition group-hover:bg-white">Open</span>
                          </a>
                        ) : (
                          <span class="flex items-center justify-between gap-3 rounded-2xl border border-ink/10 bg-lemon/80 px-4 py-3 text-sm font-black text-ink shadow-sm">
                            <span class="min-w-0 truncate">{link.label}</span>
                            <span class="shrink-0 whitespace-nowrap rounded-full bg-white/70 px-2.5 py-1 text-[11px]">{link.status}</span>
                          </span>
                        )
                      ))}
                      <a class="focus-ring group flex items-center justify-between gap-3 rounded-2xl border border-ink/10 bg-mint/80 px-4 py-3 text-sm font-black text-ink shadow-sm transition hover:-translate-y-0.5 hover:bg-mint hover:shadow-soft" href={`/personal-projects/${project.slug}`}>
                        <span class="min-w-0 truncate">Architecture Notes</span>
                        <span class="shrink-0 rounded-full bg-white/75 px-2.5 py-1 text-[11px] text-ink transition group-hover:bg-white">Open</span>
                      </a>
                    </div>
                  )}

                  {project.releaseAssets && (
                    <div class="mt-5 rounded-2xl bg-cream p-4">
                      <h4 class="font-black">Release Package</h4>
                      <div class="mt-3 grid gap-3">
                        {project.releaseAssets.map((asset) => (
                          <div class="flex flex-col gap-3 rounded-xl bg-white/80 p-4 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                              <p class="font-black">{asset.label}</p>
                              {asset.description && <p class="mt-1 text-sm leading-6 text-muted">{asset.description}</p>}
                              {asset.status && <p class="mt-2 text-sm font-bold text-cocoa">{asset.status}</p>}
                            </div>
                            {asset.href ? (
                              <a class="focus-ring inline-flex w-fit shrink-0 rounded-full bg-ink px-4 py-2 text-sm font-black text-cream transition hover:bg-cocoa" href={asset.href} target="_blank" rel="noreferrer">
                                Open Release
                              </a>
                            ) : (
                              <span class="inline-flex w-fit shrink-0 rounded-full bg-lemon px-4 py-2 text-sm font-black text-ink">File Pending</span>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                <div class="mx-auto w-full max-w-[360px] overflow-hidden rounded-[2rem] border border-ink/10 bg-ink p-2 shadow-soft">
                  {project.demoVideo && youtubeEmbedUrl ? (
                    <iframe
                      class="aspect-[9/16] w-full rounded-[1.5rem]"
                      src={youtubeEmbedUrl}
                      title={project.demoVideo.title}
                      allow="autoplay; encrypted-media; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  ) : (
                    <div class="grid aspect-[9/16] place-items-center rounded-[1.5rem] p-6 text-center text-sm font-black text-cream">
                      YouTube Demo Coming Soon
                    </div>
                  )}
                  {project.demoVideo && (
                    <div class="px-3 py-3">
                      <p class="text-sm font-black text-cream">{project.demoVideo.title}</p>
                      <p class="mt-1 text-xs leading-5 text-cream/70">{project.demoVideo.description}</p>
                    </div>
                  )}
                </div>
              </div>

              <div class="mt-8">
                {project.appScreenshots && (
                  <div>
                    <h4 class="font-black">App Screenshots</h4>
                    <div class="mt-4 grid gap-4 sm:grid-cols-3">
                      {project.appScreenshots.map((screenshot, index) => (
                        <div class="flex h-full flex-col rounded-2xl border border-ink/10 bg-white/80 p-4 shadow-sm">
                          {screenshot.src ? (
                            <img class="aspect-[831/1800] w-full rounded-xl object-cover shadow-soft" src={screenshot.src} alt={screenshot.alt ?? screenshot.title} loading="lazy" />
                          ) : (
                            <div class:list={["grid aspect-[831/1800] place-items-center rounded-xl text-center text-sm font-black text-ink shadow-soft", index % 3 === 0 ? "bg-mint" : index % 3 === 1 ? "bg-sky" : "bg-rose"]}>
                              App Image Coming Soon
                            </div>
                          )}
                          <div class="flex flex-1 flex-col">
                            <p class="mt-4 min-h-[3rem] font-black leading-6">{screenshot.title}</p>
                            <p class="mt-2 flex-1 text-sm leading-6 text-muted">{screenshot.description}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <section id="skills" class="section-shell py-16">
      <SectionTitle eyebrow="Skills" title="Skills" />
      <div class="mt-9 grid gap-5 md:grid-cols-2">
        {skillGroups.map((group) => <SkillGroup title={group.title} skills={group.skills} />)}
      </div>
      <div class="soft-card mt-6 rounded-2xl p-6 md:p-8">
        <h3 class="text-2xl font-black">Current Stack</h3>
        <p class="mt-3 leading-8 text-muted">
          永住申請アプリを継続開発しており、Jetpack Compose、Kotlin Coroutines、Room、Hilt、Material 3 に加えて、GitHub Actions を使った CI / CD も実装・運用しています。
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {currentStack.map((skill, index) => (
            <span class:list={["rounded-full px-3 py-2 text-sm font-bold text-ink", chipColors[index % chipColors.length]]}>{skill}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="section-shell py-16">
      <SectionTitle eyebrow="Career" title="Career Summary" />
      <div class="soft-card mt-9 rounded-2xl p-6 md:p-8">
        <div class="grid gap-4 border-l-4 border-mint pl-6">
          <p class="text-sm font-black text-cocoa">2022.07 - 2025.12</p>
          <h3 class="text-2xl font-black">北京達佳互聯信息技術有限公司 / Kwai - Kuaishou</h3>
          <div class="grid gap-3 sm:grid-cols-2">
            <a class="focus-ring group flex min-w-0 items-center justify-between gap-2 rounded-2xl border border-ink/10 bg-peach px-4 py-3 text-sm font-black text-ink shadow-sm transition hover:-translate-y-0.5 hover:border-cocoa/30 hover:bg-rose hover:shadow-soft" href="https://zhaopin.kuaishou.cn/#/official/jianghu/" target="_blank" rel="noreferrer">
              <span class="min-w-0 truncate">Kuaishou Careers</span>
              <span class="shrink-0 rounded-full bg-white/75 px-2.5 py-1 text-[11px] text-ink transition group-hover:bg-white">Open</span>
            </a>
            <a class="focus-ring group flex min-w-0 items-center justify-between gap-2 rounded-2xl border border-ink/10 bg-sky px-4 py-3 text-sm font-black text-ink shadow-sm transition hover:-translate-y-0.5 hover:border-cocoa/30 hover:bg-mint hover:shadow-soft" href="https://zh.wikipedia.org/wiki/%E5%BF%AB%E6%89%8B_(%E8%BB%9F%E9%AB%94)" target="_blank" rel="noreferrer">
              <span class="min-w-0 truncate">Company Background</span>
              <span class="shrink-0 rounded-full bg-white/75 px-2.5 py-1 text-[11px] text-ink transition group-hover:bg-white">Open</span>
            </a>
          </div>
          <p class="font-bold text-muted">Android Client Engineer</p>
          <p class="leading-8 text-muted">
            大規模インターネットサービスのAndroidアプリ開発に従事。TV向け機能開発、ログイン基盤刷新、IMSDK安定性改善、通信コスト最適化などを担当。
          </p>
        </div>
      </div>
    </section>

    <section id="contact" class="section-shell pb-24 pt-16">
      <div class="soft-card rounded-3xl p-6 md:p-10">
        <SectionTitle eyebrow="Contact" title="Contact" />
        <p class="mt-5 max-w-3xl text-lg leading-8 text-muted">
          Androidエンジニアとして、日本のサービス開発に長期的に携わりたいと考えています。ご連絡は以下よりお願いいたします。
        </p>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          <a class="focus-ring rounded-2xl bg-white/80 p-5 font-bold text-ink transition hover:bg-mint" href="mailto:yukiwangsnow0108@gmail.com">Email: yukiwangsnow0108@gmail.com</a>
          <a class="focus-ring rounded-2xl bg-white/80 p-5 font-bold text-ink transition hover:bg-mint" href="https://github.com/hongyi-wang0108" target="_blank" rel="noreferrer">GitHub: hongyi-wang0108</a>
          <div class="rounded-2xl bg-white/80 p-5 font-bold text-muted">LinkedIn: 後で設定</div>
          <div class="rounded-2xl bg-white/80 p-5 font-bold text-muted">Location: Tokyo, Japan</div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
